{
  "name": "devinsight",
  "displayName": "DevInsight",
  "description": "Plugin de análise evolutiva de código.",
  "version": "0.0.1",
  "publisher": "soubruno",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript"
  ],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devinsight-sidebar-container",
          "title": "DevInsight",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "devinsight-sidebar-container": [
        {
          "type": "webview",
          "id": "devinsight.sidebarView",
          "name": "Dashboard de Evolução"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "@seald-io/nedb": "^4.1.2",
    "dotenv": "^17.4.2",
    "node-fetch": "^2.7.0"
  }
}
